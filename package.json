{
  "name": "reviewable-md",
  "version": "0.1.17",
  "type": "module",
  "description": "Preview a markdown file, leave inline review comments, and copy them back to an AI for the next edit.",
  "bin": {
    "reviewable-md": "./server/cli.js"
  },
  "files": [
    "dist/",
    "server/",
    "skill/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "dev": "RMD_DEV=1 node server/cli.js",
    "build": "vite build",
    "preview": "node server/cli.js serve --no-open",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:agents": "node scripts/sync-agents.mjs",
    "prepublishOnly": "npm test && npm run build",
    "publish:npm": "npm publish --registry=https://registry.npmjs.org/",
    "publish:shopee": "node scripts/publish-with-name.mjs --name @foody/reviewable-md --registry https://npm.shopee.io/",
    "publish:all": "npm run publish:npm && npm run publish:shopee"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.21.0",
    "mermaid": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.6",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.1.0",
    "vite": "^5.4.11",
    "vitest": "^3.2.6"
  }
}
